# ── App ─────────────────────────────────────────────
PORT=3000
# Used to sign login tokens. Change to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Public base URL of the site (used in emails / PayPal return URLs)
APP_URL=http://localhost:3000
# Set to "production" when deployed (enables Secure cookies behind HTTPS).
NODE_ENV=development

# Where the SQLite file lives. On a host with a persistent disk, point this
# at the mounted volume, e.g. /data/data.sqlite  (defaults to ./data.sqlite).
DB_PATH=

# ── Cross-origin (only if NOT using the Vercel proxy) ──
# Comma-separated site origins allowed to call this API directly.
ALLOWED_ORIGIN=
# Set true when the frontend is on a different domain than the API
# (sends cookies cross-site as SameSite=None; Secure).
COOKIE_CROSS_SITE=false

# ── PayPal (Checkout / Orders API) ──────────────────
# Get sandbox credentials at https://developer.paypal.com/dashboard/applications
# Leave blank to run in DEMO mode (payments are simulated, no real PayPal calls).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" or "live"
PAYPAL_ENV=sandbox

# ── Company bank account (shown for IBAN / SEPA pay-in) ──
BANK_BENEFICIARY=CubaRemesa S.L.
BANK_NAME=Example Bank
BANK_IBAN=ES00 0000 0000 0000 0000 0000
BANK_BIC=EXAMPLEXXX

# ── Auto exchange rate (elTOQUE TRMI) ───────────────
# Free token: register at https://eltoque.com (API tasas). Leave blank to keep rates manual.
RATE_API_URL=https://tasas.eltoque.com/v1/trmi
RATE_API_TOKEN=

# ── Default admin (created on first run / seed) ─────
ADMIN_EMAIL=admin@cubaremesa.com
ADMIN_PASSWORD=admin1234
